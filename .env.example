# ElectIQ Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Required: Google Gemini API Key
# Get yours free at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Civic Information API Key (for Phase stretch goals)
# VITE_CIVIC_API_KEY=your_civic_api_key_here

# Optional: Target country for election process (IN = India, US = United States)
# VITE_APP_COUNTRY=IN
